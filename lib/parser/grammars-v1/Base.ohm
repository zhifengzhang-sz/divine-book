Base {
  varRef
    = lower+              -- letters
    | digits "." digits   -- decimal
    | digits              -- integer

  digits = digit+

  stateName = "【" stateNameChars "】"
  stateNameChars = (~"】" any)+

  cnNumber = cnDigit+
  cnDigit = "一" | "二" | "三" | "四" | "五" | "六" | "七" | "八" | "九" | "十" | "两"
  cnNumberOrDigit = cnNumber | digits

  gapTo<target> = (~target any)*
}
