{
  "name": "divine-book",
  "private": true,
  "type": "module",
  "workspaces": ["lib"],
  "scripts": {
    "check": "tsc --noEmit && biome check app/ lib/",
    "test": "bun test",
    "parse": "bun scripts/gen-yaml.ts && bun scripts/validate-yaml.ts",
    "parse:legacy": "bun app/parse-main-skills.ts -o data/yaml/books.yaml && bun app/parse-affixes.ts -o data/yaml/affixes.yaml && bun scripts/validate-yaml.ts",
    "migrate": "bun scripts/migrate-to-json.ts",
    "editor": "bun app/editor/serve.ts",
    "export-md": "bun scripts/gen-markdown.ts",
    "viz": "bun app/viz/serve.ts",
    "parser-viz": "bun app/parser-viz/serve.ts",
    "rag": "bun scripts/rag.ts"
  },
  "dependencies": {
    "ohm-js": "^17.5.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "xstate": "^5.28.0",
    "yaml": "^2.7.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "@types/bun": "^1.3.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  }
}
